{
  "name": "parlanode",
  "version": "0.0.0",
  "author": "Danes je nov dan",
  "license": "Unlicense",
  "type": "module",
  "scripts": {
    "dev": "vite --config build/vite.config.dev.js",
    "build": "yarn build:client && yarn build:server && yarn build:locales",
    "build:client": "vite build --config build/vite.config.build.js --ssrManifest --outDir dist/client",
    "build:server": "SSR=1 vite build --config build/vite.config.build.js --ssr --outDir dist/server",
    "build:locales": "node build/build-locales.js",
    "start": "node server/index.js",
    "start:watch": "nodemon -e js,cjs,mjs,vue,html server/index.js",
    "lint": "yarn lint:eslint && yarn lint:card-names && yarn lint:locale-names && yarn lint:locale-keys",
    "lint:eslint": "eslint . --ext js,cjs,mjs,vue",
    "lint:card-names": "node build/lint-card-names.js",
    "lint:locale-names": "node build/lint-locale-names.js",
    "lint:locale-keys": "node build/lint-locale-keys.js"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@immobiliarelabs/fastify-sentry": "^9.0.1",
    "@intlify/unplugin-vue-i18n": "^6.0.8",
    "@rollup/plugin-virtual": "^3.0.2",
    "@rollup/plugin-yaml": "^4.1.2",
    "@sentry/node": "^9.28.1",
    "@sentry/vue": "^9.28.1",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vue/server-renderer": "^3.5.16",
    "axios": "^1.9.0",
    "d3": "^7.9.0",
    "date-fns": "^4.1.0",
    "fastify": "^5.3.3",
    "fs-extra": "^11.3.0",
    "html-safe-json": "^2.0.3",
    "lodash-es": "^4.17.21",
    "recaptcha-v3": "^1.11.3",
    "remarkable": "^2.0.1",
    "sass": "^1.89.2",
    "vite": "^6.3.5",
    "vue": "^3.5.16",
    "vue-i18n": "^11.1.5"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "@types/lodash-es": "^4.17.12",
    "eslint": "^8.2.0",
    "eslint-config-airbnb-base": "15.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-alias": "^1.1.2",
    "eslint-plugin-import": "^2.25.2",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-vue": "^8.5.0",
    "glob": "^11.0.2",
    "js-yaml": "^4.1.0",
    "nodemon": "^3.1.10",
    "prettier": "^3.5.3"
  }
}
