{
  "name": "parlanode",
  "version": "0.0.0",
  "author": "Danes je nov dan",
  "license": "Unlicense",
  "type": "module",
  "scripts": {
    "dev": "vite --config build/vite.config.dev.js",
    "build": "yarn build:client && yarn build:server && yarn build:locales",
    "build:client": "vite build --config build/vite.config.build.js --ssrManifest --outDir dist/client",
    "build:server": "SSR=1 vite build --config build/vite.config.build.js --ssr --outDir dist/server",
    "build:locales": "node build/build-locales.js",
    "start": "node --import ./instrument.js server/index.js",
    "start:watch": "nodemon -e js,cjs,mjs,vue,html --import ./instrument.js server/index.js",
    "lint": "yarn lint:eslint && yarn lint:component-names",
    "lint:eslint": "eslint .",
    "lint:component-names": "node build/lint-component-names.js"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@rollup/plugin-virtual": "^3.0.2",
    "@rollup/plugin-yaml": "^4.1.2",
    "@sentry/node": "^10.22.0",
    "@sentry/vue": "^10.22.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/server-renderer": "^3.5.22",
    "axios": "^1.12.2",
    "d3": "^7.9.0",
    "date-fns": "^4.1.0",
    "fastify": "^5.6.1",
    "fs-extra": "^11.3.2",
    "html-safe-json": "^2.0.3",
    "lodash-es": "^4.17.21",
    "recaptcha-v3": "^1.11.3",
    "remarkable": "^2.0.1",
    "sass": "^1.93.2",
    "vite": "^7.1.12",
    "vue": "^3.5.22",
    "vue-i18n": "^11.1.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "@types/d3": "^7.4.3",
    "@types/lodash-es": "^4.17.12",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-alias": "^1.1.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-vue": "^10.5.1",
    "glob": "^11.0.3",
    "globals": "^16.4.0",
    "js-yaml": "^4.1.0",
    "nodemon": "^3.1.10",
    "prettier": "^3.6.2",
    "vue-eslint-parser": "^10.2.0"
  }
}
