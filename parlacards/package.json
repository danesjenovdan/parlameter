{
  "name": "parlanode",
  "version": "0.0.0",
  "author": "Danes je nov dan",
  "license": "Unlicense",
  "type": "module",
  "scripts": {
    "dev": "vite --config build/vite.config.dev.js",
    "build": "yarn build:client && yarn build:server && yarn build:locales",
    "build:client": "vite build --config build/vite.config.build.js --ssrManifest --outDir dist/client",
    "build:server": "SSR=1 vite build --config build/vite.config.build.js --ssr --outDir dist/server",
    "build:locales": "node build/build-locales.js",
    "start": "node --import ./instrument.js server/index.js",
    "start:watch": "nodemon -e js,cjs,mjs,vue,html --import ./instrument.js server/index.js",
    "lint": "yarn lint:eslint && yarn lint:component-names",
    "lint:eslint": "eslint .",
    "lint:component-names": "node build/lint-component-names.js"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@rollup/plugin-virtual": "^3.0.2",
    "@rollup/plugin-yaml": "^4.1.2",
    "@sentry/node": "^10.53.1",
    "@sentry/vue": "^10.53.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/server-renderer": "^3.5.34",
    "axios": "^1.16.1",
    "d3": "^7.9.0",
    "date-fns": "^4.2.1",
    "fastify": "^5.8.5",
    "fs-extra": "^11.3.5",
    "html-safe-json": "^2.0.3",
    "lodash-es": "^4.18.1",
    "recaptcha-v3": "^1.11.3",
    "remarkable": "^2.0.1",
    "sass": "^1.99.0",
    "vite": "^8.0.13",
    "vue": "^3.5.34",
    "vue-i18n": "^11.4.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/d3": "^7.4.3",
    "@types/lodash-es": "^4.17.12",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-alias": "^1.1.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^10.9.1",
    "glob": "^13.0.6",
    "globals": "^17.6.0",
    "js-yaml": "^4.1.1",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.3",
    "vue-eslint-parser": "^10.4.0"
  }
}
